<view class="container">
  <!-- 客户基本信息 -->
  <view class="form-section">
    <view class="section-label">客户信息</view>
    <view class="form-card">
      <view class="form-row">
        <text class="form-label">姓名</text>
        <input 
          class="form-input" 
          placeholder="请输入客户姓名" 
          placeholder-class="form-placeholder"
          value="{{form.petName}}" 
          bindinput="onInput" 
          data-field="petName" 
        />
      </view>
      <view class="form-divider"></view>
      <view class="form-row">
        <text class="form-label">手机号</text>
        <input 
          class="form-input" 
          type="number" 
          placeholder="请输入11位手机号" 
          placeholder-class="form-placeholder"
          maxlength="11" 
          value="{{form.phone}}" 
          bindinput="onInput" 
          data-field="phone" 
        />
      </view>
      <view class="form-divider"></view>
      <view class="form-row">
        <text class="form-label">性别</text>
        <view class="gender-picker">
          <view class="gender-option {{form.gender === 'male' ? 'active' : ''}}" bindtap="onGender" data-value="male">
            <text>男</text>
          </view>
          <view class="gender-option {{form.gender === 'female' ? 'active' : ''}}" bindtap="onGender" data-value="female">
            <text>女</text>
          </view>
        </view>
      </view>
      <view class="form-divider"></view>
      <view class="form-row form-row-textarea">
        <text class="form-label">备注</text>
        <textarea 
          class="form-textarea" 
          placeholder="添加客户备注（选填）" 
          placeholder-class="form-placeholder"
          value="{{form.notes}}" 
          bindinput="onInput" 
          data-field="notes"
          auto-height
          maxlength="200"
        />
      </view>
    </view>
  </view>

  <!-- 宠物档案（编辑模式） -->
  <view class="form-section" wx:if="{{id}}">
    <view class="section-label-row">
      <text class="section-label">宠物档案</text>
      <text class="section-count">{{pets.length}}只</text>
    </view>
    <view class="form-card" wx:if="{{pets.length > 0}}">
      <block wx:for="{{pets}}" wx:key="id">
        <view class="pet-row">
          <view class="pet-row-left" bindtap="editPet" data-id="{{item.id}}">
            <view class="pet-avatar-sm">
              <text class="pet-emoji">{{item.species === 'dog' ? '🐕' : item.species === 'cat' ? '🐱' : '🐾'}}</text>
            </view>
            <view class="pet-row-info">
              <text class="pet-row-name">{{item.name}}</text>
              <text class="pet-row-breed">{{item.breed}}</text>
            </view>
          </view>
          <view class="pet-row-actions">
            <view class="pet-action-btn edit" bindtap="editPet" data-id="{{item.id}}">
              <text>编辑</text>
            </view>
            <view class="pet-action-btn delete" bindtap="deletePet" data-id="{{item.id}}">
              <text>删除</text>
            </view>
          </view>
        </view>
        <view class="form-divider indent" wx:if="{{index < pets.length - 1}}"></view>
      </block>
    </view>
    <view class="add-pet-row" bindtap="addPet" hover-class="add-pet-hover">
      <text class="add-pet-icon">+</text>
      <text class="add-pet-text">添加宠物</text>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-spacer"></view>

  <!-- 底部保存按钮 -->
  <view class="action-bar">
    <button class="btn-save" bindtap="submit" disabled="{{loading}}">
      {{loading ? '保存中...' : '保存'}}
    </button>
  </view>
</view>
