/* ============================================
   客户详情页 - iOS 极简风格
   ============================================ */

.container {
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* 个人资料区 */
.profile-section {
  padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-lg);
}

.profile-card {
  background-color: var(--color-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-xl);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-card);
}

.profile-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary), #5856D6);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-md);
}

.avatar-text {
  color: #FFFFFF;
  font-size: var(--font-xxl);
  font-weight: 600;
}

.profile-name {
  font-size: var(--font-xl);
  font-weight: 600;
  color: var(--color-label);
  margin-bottom: 8rpx;
}

.profile-name-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-bottom: 8rpx;
}

.gender-badge {
  font-size: var(--font-md);
  color: #007AFF;
  font-weight: 600;
}

.gender-badge.female {
  color: #FF2D55;
}

.profile-phone {
  font-size: var(--font-base);
  color: var(--color-tertiary-label);
  margin-bottom: var(--spacing-md);
}

.profile-tags {
  display: flex;
  gap: var(--spacing-sm);
  flex-wrap: wrap;
  justify-content: center;
}

.tag-item {
  font-size: var(--font-xs);
  color: var(--color-primary);
  background-color: var(--color-primary-light);
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
}

/* 统计区域 */
.stats-section {
  padding: 0 var(--spacing-lg) var(--spacing-md);
}

.stats-card {
  display: flex;
  align-items: center;
  background-color: var(--color-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg) 0;
  box-shadow: var(--shadow-card);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-label);
  letter-spacing: -0.5rpx;
}

.stat-label {
  font-size: var(--font-xs);
  color: var(--color-tertiary-label);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: var(--color-separator);
}

/* 分区 */
.section {
  padding: var(--spacing-md) var(--spacing-lg);
}

.section-title-bar {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-label);
}

.section-count {
  font-size: var(--font-sm);
  color: var(--color-tertiary-label);
  margin-left: var(--spacing-sm);
}

.section-action {
  margin-left: auto;
}

.action-text {
  font-size: var(--font-base);
  color: var(--color-primary);
  font-weight: 500;
}

/* 宠物卡片 */
.pets-scroll {
  width: 100%;
  white-space: nowrap;
}

.pets-row {
  display: flex;
  gap: var(--spacing-md);
  padding-bottom: var(--spacing-xs);
}

.pet-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: var(--color-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg) var(--spacing-xl);
  min-width: 220rpx;
  box-shadow: var(--shadow-card);
  transition: transform 0.15s ease;
}

.pet-card-hover {
  transform: scale(0.96);
  background-color: var(--color-fill);
}

.pet-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background-color: var(--color-fill);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-sm);
}

.pet-emoji {
  font-size: 48rpx;
}

.pet-photo {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-bottom: var(--spacing-sm);
}

.pet-name {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-label);
  margin-bottom: 4rpx;
  white-space: nowrap;
}

.pet-breed {
  font-size: var(--font-xs);
  color: var(--color-tertiary-label);
  margin-bottom: var(--spacing-sm);
  white-space: nowrap;
}

.pet-badges {
  display: flex;
  gap: 8rpx;
}

.pet-badge {
  font-size: var(--font-xs);
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-fill);
  border-radius: 50%;
}

/* 空宠物 */
.empty-pets {
  background-color: var(--color-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-xl);
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx dashed var(--color-separator-opaque);
}

.empty-pets-hover {
  background-color: var(--color-fill);
}

.empty-pets-icon {
  font-size: 56rpx;
  margin-bottom: var(--spacing-sm);
  opacity: 0.4;
}

.empty-pets-text {
  font-size: var(--font-base);
  color: var(--color-primary);
  font-weight: 500;
}

/* 消费记录 */
.history-card {
  background-color: var(--color-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.history-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-lg);
}

.history-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
  min-width: 0;
}

.history-items {
  font-size: var(--font-base);
  font-weight: 500;
  color: var(--color-label);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-date {
  font-size: var(--font-xs);
  color: var(--color-tertiary-label);
}

.history-amount {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-label);
  flex-shrink: 0;
  margin-left: var(--spacing-md);
}

.history-separator {
  height: 1rpx;
  background-color: var(--color-separator);
  margin-left: var(--spacing-lg);
}

.empty-inline {
  background-color: var(--color-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-xl);
  text-align: center;
}

.empty-inline-text {
  font-size: var(--font-base);
  color: var(--color-tertiary-label);
}

/* 底部占位 */
.bottom-spacer {
  height: 200rpx;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-top: 1rpx solid var(--color-separator);
  padding: var(--spacing-md) var(--spacing-lg);
  padding-bottom: calc(var(--spacing-md) + env(safe-area-inset-bottom));
  z-index: 100;
}

.action-bar-inner {
  display: flex;
  gap: var(--spacing-md);
}

.btn-action-primary {
  flex: 2;
  background-color: var(--color-primary);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-md);
  height: 92rpx;
  line-height: 92rpx;
  font-size: var(--font-md);
  font-weight: 600;
  padding: 0;
}

.btn-action-primary::after {
  border: none;
}

.btn-action-primary:active {
  opacity: 0.8;
}

.btn-action-secondary {
  flex: 1;
  background-color: var(--color-primary-light);
  color: var(--color-primary);
  border: none;
  border-radius: var(--radius-md);
  height: 92rpx;
  line-height: 92rpx;
  font-size: var(--font-md);
  font-weight: 600;
  padding: 0;
}

.btn-action-secondary::after {
  border: none;
}

.btn-action-secondary:active {
  opacity: 0.7;
}

.btn-action-danger {
  background-color: rgba(255, 59, 48, 0.08);
  color: var(--color-danger);
  border: none;
  border-radius: var(--radius-md);
  height: 92rpx;
  line-height: 92rpx;
  font-size: var(--font-md);
  font-weight: 600;
  padding: 0 32rpx;
  flex-shrink: 0;
}

.btn-action-danger::after {
  border: none;
}

.btn-action-danger:active {
  opacity: 0.7;
}
