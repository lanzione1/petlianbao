<view class="container">
  <view class="service-list">
    <view class="service-item" wx:for="{{services}}" wx:key="id">
      <view class="service-info">
        <text class="service-name">{{item.name}}</text>
        <view class="service-meta">
          <text class="service-price">¥{{item.price}}</text>
          <text class="service-duration">{{item.duration}}分钟</text>
        </view>
      </view>
      <view class="service-actions">
        <view class="switch-wrap">
          <switch checked="{{item.isActive}}" bindchange="toggleActive" data-id="{{item.id}}" color="#667eea" />
        </view>
        <view class="btn-edit" bindtap="editService" data-id="{{item.id}}">编辑</view>
      </view>
    </view>
    <view class="empty" wx:if="{{services.length === 0}}">
      <text>暂无服务项目</text>
      <text class="hint">点击下方按钮添加</text>
    </view>
  </view>

  <view class="fab" bindtap="addService">+</view>

  <view class="modal" wx:if="{{showModal}}">
    <view class="modal-mask" bindtap="closeModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">{{editId ? '编辑服务' : '添加服务'}}</text>
        <text class="modal-close" bindtap="closeModal">×</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">服务名称</text>
          <input class="form-input" placeholder="如：洗澡、精剪" value="{{form.name}}" bindinput="onInput" data-field="name" />
        </view>
        <view class="form-item">
          <text class="form-label">价格（元）</text>
          <input class="form-input" type="digit" placeholder="请输入价格" value="{{form.price}}" bindinput="onInput" data-field="price" />
        </view>
        <view class="form-item">
          <text class="form-label">时长（分钟）</text>
          <input class="form-input" type="number" placeholder="请输入时长" value="{{form.duration}}" bindinput="onInput" data-field="duration" />
        </view>
        <view class="form-item">
          <text class="form-label">每日限制</text>
          <input class="form-input" type="number" placeholder="0表示不限" value="{{form.dailyLimit}}" bindinput="onInput" data-field="dailyLimit" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="closeModal">取消</button>
        <button class="btn-confirm" bindtap="submit">保存</button>
      </view>
    </view>
  </view>
</view>
