<view class="container">
  <view class="date-header">
    <view class="date-nav" bindtap="prevDay">◀</view>
    <view class="date-text" bindlongpress="seedTestData">{{ dateText }}</view>
    <view class="date-nav" bindtap="nextDay">▶</view>
  </view>

  <view class="reminder-banner" bindtap="goReminders" wx:if="{{reminderCount > 0}}">
    <text class="reminder-icon">🔔</text>
    <text class="reminder-text">您有 {{reminderCount}} 条宠物提醒待处理</text>
    <text class="reminder-arrow">›</text>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索客户姓名或电话" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
      <text class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">✕</text>
    </view>
  </view>

  <view class="tabs">
    <view class="tab {{currentTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">
      待服务 ({{pendingCount}})
    </view>
    <view class="tab {{currentTab === 'completed' ? 'active' : ''}}" bindtap="switchTab" data-tab="completed">
      已完成 ({{completedCount}})
    </view>
    <view class="tab {{currentTab === 'customer_cancelled' ? 'active' : ''}} tab-customer-cancel" bindtap="switchTab" data-tab="customer_cancelled" wx:if="{{customerCancelledCount > 0}}">
      🔔 客户取消 ({{customerCancelledCount}})
    </view>
  </view>

  <scroll-view scroll-y class="appointment-list">
    <!-- 骨架屏 -->
    <view class="skeleton" wx:if="{{loading}}">
      <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="index">
        <view class="skeleton-header">
          <view class="skeleton-time"></view>
          <view class="skeleton-status"></view>
        </view>
        <view class="skeleton-body">
          <view class="skeleton-line"></view>
          <view class="skeleton-line short"></view>
        </view>
      </view>
    </view>

    <block wx:for="{{currentAppointments}}" wx:key="id" wx:if="{{!loading}}">
      <view class="appointment-card" bindtap="showDetail" data-id="{{item.id}}">
        <view class="card-header">
          <text class="time">{{item.timeStr}}</text>
          <text class="status status-{{item.status}}">{{statusText[item.status]}}</text>
        </view>
        
        <view class="card-main">
          <view class="customer-row">
            <text class="label">客户:</text>
            <text class="customer-name">{{item.customer.petName}}</text>
            <text class="phone">{{item.customer.phone}}</text>
          </view>
          
          <view class="pet-row" wx:if="{{item.pets && item.pets.length > 0}}">
            <text class="label">宠物:</text>
            <view class="pet-tags">
              <text class="pet-tag" wx:for="{{item.pets}}" wx:for-item="pet" wx:key="id">
                {{pet.species === 'dog' ? '🐕' : pet.species === 'cat' ? '🐱' : '🐾'}} {{pet.name}}
              </text>
            </view>
          </view>
          
          <view class="service-row">
            <text class="label">服务:</text>
            <text class="service-name">{{item.service.name}}</text>
            <text class="price">¥{{item.service.price}}</text>
          </view>
        </view>
        
        <view class="card-footer" wx:if="{{item.notes}}">
          <text class="notes">备注: {{item.notes}}</text>
        </view>
        
        <!-- 客户取消信息 -->
        <view class="cancel-info" wx:if="{{item.status === 'cancelled_by_customer'}}">
          <view class="cancel-reason" wx:if="{{item.cancelReason}}">
            <text class="cancel-icon">💬</text>
            <text class="cancel-text">{{item.cancelReason}}</text>
          </view>
          <view class="cancel-time" wx:if="{{item.cancelledAt}}">
            <text class="time-text">取消于: {{item.cancelledAt}}</text>
          </view>
        </view>
        
        <!-- 待服务操作按钮 -->
        <view class="card-actions" wx:if="{{item.status === 'pending'}}" catchtap="{{true}}">
          <button size="mini" catchtap="cancelAppointment" data-id="{{item.id}}" class="btn-cancel-mini">取消预约</button>
          <button size="mini" type="primary" catchtap="completeService" data-id="{{item.id}}">完成服务</button>
        </view>
        
        <!-- 客户取消操作按钮 -->
        <view class="card-actions" wx:if="{{item.status === 'cancelled_by_customer'}}" catchtap="{{true}}">
          <button size="mini" catchtap="callCustomer" data-phone="{{item.customer.phone}}" class="btn-call">📞 致电客户</button>
          <button size="mini" type="primary" catchtap="markFollowedUp" data-id="{{item.id}}">✓ 已回访</button>
        </view>
      </view>
    </block>
    
    <view class="empty-state" wx:if="{{currentAppointments.length === 0}}">
      <view class="empty-icon">📅</view>
      <text class="empty-title">暂无{{currentTab === 'pending' ? '待服务' : currentTab === 'completed' ? '已完成' : ''}}预约</text>
      <text class="empty-desc">点击右下角按钮添加新预约</text>
      <button class="empty-btn" bindtap="quickAddAppointment">添加预约</button>
    </view>
  </scroll-view>

  <view class="summary">
    <view class="summary-item">
      <text class="label">今日预约</text>
      <text class="value">{{todayTotalCount || 0}}</text>
    </view>
    <view class="summary-item">
      <text class="label">今日订单</text>
      <text class="value">{{summary.orderCount || 0}}</text>
    </view>
    <view class="summary-item">
      <text class="label">今日营收</text>
      <text class="value">¥{{summary.totalRevenue || 0}}</text>
    </view>
  </view>

  <!-- 快速添加按钮 -->
  <view class="fab-button" bindtap="quickAddAppointment">
    <text class="fab-icon">+</text>
  </view>
</view>
