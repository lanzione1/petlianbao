.container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.tabs {
  display: flex;
  background: white;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  color: #666;
  font-size: 28rpx;
}

.tab.active {
  color: #667eea;
  border-bottom: 4rpx solid #667eea;
}

.content {
  flex: 1;
  padding: 20rpx;
}

.panel {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.date-picker {
  background: white;
  padding: 20rpx;
  border-radius: 16rpx;
}

.picker-btn {
  text-align: center;
  color: #667eea;
  font-size: 28rpx;
}

.stats-card {
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
}

.stats-main {
  text-align: center;
  padding-bottom: 20rpx;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.stats-main .stats-value {
  font-size: 56rpx;
  font-weight: 500;
  color: #667eea;
}

.stats-main .stats-label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.stats-row {
  display: flex;
}

.stats-row.three-col .stats-item {
  flex: 1;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-item .stats-value {
  display: block;
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
}

.stats-item .stats-value.green {
  color: #52c41a;
}

.stats-item .stats-value.red {
  color: #ff4d4f;
}

.stats-item .stats-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.chart-section {
  background: white;
  padding: 24rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.chart-placeholder {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 300rpx;
  padding: 20rpx 0;
}

.bar {
  width: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 10rpx;
  position: relative;
}

.bar-value {
  position: absolute;
  top: -40rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18rpx;
  color: #666;
  white-space: nowrap;
}

.section {
  background: white;
  padding: 24rpx;
  border-radius: 16rpx;
}

.rank-list {
  display: flex;
  flex-direction: column;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-num {
  width: 48rpx;
  height: 48rpx;
  background: #667eea;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-right: 16rpx;
}

.rank-item:nth-child(1) .rank-num {
  background: #ffd700;
}

.rank-item:nth-child(2) .rank-num {
  background: #c0c0c0;
}

.rank-item:nth-child(3) .rank-num {
  background: #cd7f32;
}

.rank-info {
  flex: 1;
}

.rank-name {
  display: block;
  font-size: 28rpx;
  color: #333;
}

.rank-count {
  font-size: 24rpx;
  color: #999;
}

.rank-amount {
  font-size: 30rpx;
  font-weight: 500;
  color: #ff6b6b;
}

.empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
}
