<view class="container">
  <view class="header">
    <view class="avatar">{{userInfo.shopName ? userInfo.shopName[0] : '宠'}}</view>
    <view class="info">
      <text class="name">{{userInfo.shopName || '未设置店名'}}</text>
      <text class="plan">{{userInfo.planType === 'professional' ? '专业版' : '免费版'}}</text>
    </view>
  </view>

  <view class="menu">
    <view class="menu-item" wx:if="{{isAdmin}}" bindtap="goStaff">
      <text class="menu-label">店员管理</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" wx:if="{{isAdmin}}" bindtap="goLogs">
      <text class="menu-label">操作日志</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goServices">
      <text class="menu-label">服务管理</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goReports">
      <text class="menu-label">数据报表</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goSettings">
      <text class="menu-label">店铺设置</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="menu">
    <view class="menu-item" bindtap="upgrade">
      <text class="menu-label">升级专业版</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" wx:if="{{isAdmin}}" bindtap="devSeed">
      <text class="menu-label" style="color:#667eea;">🛠 创建测试数据</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="feedback">
      <text class="menu-label">意见反馈</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="about">
      <text class="menu-label">关于我们</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="version">
    <text>宠联宝 v1.0.0</text>
  </view>
</view>
