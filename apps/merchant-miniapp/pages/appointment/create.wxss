.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.form-section {
  background: white;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 24rpx;
}

.section-title .required {
  color: #ff4d4f;
  margin-left: 4rpx;
}

/* 客户选择 */
.customer-select {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.customer-info {
  display: flex;
  flex-direction: column;
}

.customer-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.customer-phone {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.placeholder {
  font-size: 30rpx;
  color: #999;
}

.arrow {
  font-size: 32rpx;
  color: #999;
}

/* 宠物列表 */
.pet-loading {
  padding: 40rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.pet-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.pet-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.pet-item.selected {
  background: #f0f3ff;
  border-color: #667eea;
}

.pet-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.pet-icon {
  font-size: 40rpx;
}

.pet-detail {
  display: flex;
  flex-direction: column;
}

.pet-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.pet-breed {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.pet-check {
  width: 40rpx;
  height: 40rpx;
  background: #667eea;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pet-check .check-icon {
  color: white;
  font-size: 24rpx;
  margin: 0;
}

/* 无宠物提示 */
.pet-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.pet-empty .empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.pet-empty .empty-text {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.pet-empty .empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.add-pet-btn {
  background: #667eea;
  color: white;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
  border-radius: 8rpx;
  border: none;
}

.add-pet-btn::after {
  border: none;
}

/* 添加宠物链接 */
.add-pet-link {
  margin-top: 16rpx;
  padding: 20rpx;
  text-align: center;
  color: #667eea;
  font-size: 28rpx;
}

/* 服务列表 */
.service-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.service-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.service-item.selected {
  background: #f0f3ff;
  border-color: #667eea;
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.service-name {
  font-size: 30rpx;
  color: #333;
}

.service-duration {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.service-price {
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: 500;
  margin-right: 16rpx;
}

/* 时间选择 */
.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
}

/* 备注输入 */
.notes-input {
  width: 100%;
  height: 160rpx;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.notes-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 提交栏 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: white;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.btn-submit {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-size: 32rpx;
  border-radius: 12rpx;
}

.btn-submit[disabled] {
  opacity: 0.6;
  background: #ccc;
}
