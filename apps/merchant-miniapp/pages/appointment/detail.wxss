.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

/* 状态卡片 */
.status-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  color: white;
}

.status-pending {
  background: linear-gradient(135deg, #fa8c16 0%, #ff9c6e 100%);
}

.status-confirmed {
  background: linear-gradient(135deg, #1890ff 0%, #69c0ff 100%);
}

.status-completed {
  background: linear-gradient(135deg, #52c41a 0%, #95de64 100%);
}

.status-cancelled {
  background: linear-gradient(135deg, #999 0%, #ccc 100%);
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.status-time {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 分区样式 */
.section {
  margin: 20rpx;
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

/* 信息卡片 */
.info-card {
  padding: 20rpx 30rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row .label {
  font-size: 28rpx;
  color: #999;
  min-width: 140rpx;
}

.info-row .value {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.info-row .price {
  color: #ff6b6b;
  font-weight: 500;
}

.info-row .phone {
  color: #1890ff;
}

.info-row .call-icon {
  font-size: 36rpx;
  padding: 8rpx;
}

.tags {
  display: flex;
  gap: 8rpx;
}

.tag {
  font-size: 22rpx;
  color: #667eea;
  background: #f0f3ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 宠物列表 */
.pet-list {
  padding: 20rpx 30rpx;
}

.pet-card {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.pet-card:last-child {
  border-bottom: none;
}

.pet-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #f5f5f5;
}

.pet-info {
  flex: 1;
}

.pet-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.pet-meta {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.pet-tags {
  display: flex;
  gap: 12rpx;
}

.pet-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.pet-tag.warning {
  color: #ff4d4f;
  background: #fff1f0;
}

.pet-tag.info {
  color: #1890ff;
  background: #e6f7ff;
}

/* 备注卡片 */
.notes-card {
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 历史记录 */
.history-list {
  padding: 0 30rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-date {
  font-size: 26rpx;
  color: #999;
  min-width: 160rpx;
}

.history-service {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.history-amount {
  font-size: 28rpx;
  color: #ff6b6b;
  font-weight: 500;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  background: white;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.action-bar button {
  flex: 1;
  margin: 0;
  font-size: 28rpx;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-confirm {
  background: #e6f7ff;
  color: #1890ff;
}

.btn-complete {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}
