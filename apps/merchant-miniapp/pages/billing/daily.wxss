.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 150rpx;
}

.date-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.date-nav {
  padding: 16rpx 32rpx;
  font-size: 28rpx;
}

.date-text {
  font-size: 32rpx;
  font-weight: 500;
  margin: 0 40rpx;
}

.summary-card {
  background: white;
  margin: -20rpx 20rpx 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.summary-row {
  display: flex;
}

.summary-row:first-child {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.summary-item {
  flex: 1;
  text-align: center;
}

.summary-item.main {
  flex: none;
  width: 100%;
}

.summary-value {
  display: block;
  font-size: 48rpx;
  font-weight: 500;
  color: #333;
}

.summary-item.main .summary-value {
  font-size: 56rpx;
  color: #667eea;
}

.summary-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.section {
  background: white;
  margin: 20rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.payment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.payment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.payment-method {
  font-size: 28rpx;
  color: #333;
}

.payment-info {
  text-align: right;
}

.payment-amount {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.payment-count {
  font-size: 24rpx;
  color: #999;
}

.service-list {
  display: flex;
  flex-direction: column;
}

.service-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.service-item:last-child {
  border-bottom: none;
}

.service-rank {
  width: 48rpx;
  height: 48rpx;
  background: #667eea;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-right: 16rpx;
}

.service-info {
  flex: 1;
}

.service-name {
  display: block;
  font-size: 28rpx;
  color: #333;
}

.service-count {
  font-size: 24rpx;
  color: #999;
}

.service-revenue {
  font-size: 30rpx;
  font-weight: 500;
  color: #ff6b6b;
}

.cash-check {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.cash-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.cash-label {
  font-size: 28rpx;
  color: #666;
}

.cash-value {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.cash-value.positive {
  color: #52c41a;
}

.cash-value.negative {
  color: #ff4d4f;
}

.cash-input {
  width: 200rpx;
  padding: 12rpx 16rpx;
  background: white;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  text-align: right;
  font-size: 28rpx;
}

.empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx;
  background: white;
  border-top: 1rpx solid #eee;
}

.btn-submit {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
}
