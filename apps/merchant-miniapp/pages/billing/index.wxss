.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 200rpx;
}

.section {
  background: white;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.customer-select {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.customer-select .placeholder {
  color: #999;
}

.customer-select .arrow {
  color: #999;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.service-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.checked {
  background: #667eea;
  border-color: #667eea;
  color: white;
}

.service-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
}

.service-info .name {
  font-size: 28rpx;
  color: #333;
}

.service-info .price {
  font-size: 28rpx;
  color: #ff6b6b;
}

.custom-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.custom-item input {
  flex: 1;
  padding: 16rpx;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.custom-item .remove {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff4d4f;
  font-size: 40rpx;
}

.add-custom {
  text-align: center;
  padding: 20rpx;
  color: #667eea;
  font-size: 28rpx;
}

.total-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 24rpx;
  background: white;
  margin-bottom: 20rpx;
}

.total-section .label {
  font-size: 30rpx;
  color: #333;
}

.total-section .amount {
  font-size: 40rpx;
  color: #ff6b6b;
  font-weight: 500;
}

.payment-methods {
  display: flex;
  gap: 20rpx;
}

.method {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.method.active {
  background: #667eea;
  border-color: #667eea;
  color: white;
}

.staff-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.staff-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  min-width: 150rpx;
}

.staff-item.active {
  background: #f0f3ff;
  border-color: #667eea;
}

.staff-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #667eea;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 12rpx;
}

.staff-name {
  font-size: 26rpx;
  color: #333;
}

.submit-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx;
  background: white;
  border-top: 1rpx solid #eee;
}

.submit-btn {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.submit-btn:disabled {
  opacity: 0.5;
}
