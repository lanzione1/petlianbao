.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
  padding-bottom: 180rpx;
}

.pet-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.loading {
  padding: 60rpx;
  text-align: center;
  color: #999;
}

.empty {
  padding: 80rpx 40rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

.pet-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.pet-card:last-child {
  border-bottom: none;
}

.pet-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.pet-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.pet-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.pet-breed {
  font-size: 26rpx;
  color: #666;
  margin-top: 6rpx;
}

.pet-weight {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.arrow {
  color: #ccc;
  font-size: 32rpx;
}

.btn-add {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
}
