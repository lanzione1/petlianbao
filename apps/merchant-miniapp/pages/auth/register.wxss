.container {
  padding: 40rpx;
  background: #fff;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.label-row {
  margin-bottom: 12rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
}

input, .picker {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker {
  display: flex;
  align-items: center;
  color: #333;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  margin-top: 60rpx;
  border: none;
}

.dev-login {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.dev-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  text-align: center;
}

.dev-btn {
  margin-bottom: 16rpx;
  background: #fff;
  border: 1rpx solid #ddd;
  font-size: 28rpx;
}

.dev-toggle {
  text-align: center;
  margin-top: 60rpx;
  padding: 20rpx;
  color: #999;
  font-size: 24rpx;
}