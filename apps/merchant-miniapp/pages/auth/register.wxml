<view class="container">
  <view class="header">
    <text class="title">商家入驻</text>
    <text class="subtitle">填写店铺信息开始经营</text>
  </view>

  <view wx:if="{{showDevLogin}}" class="dev-login">
    <view class="dev-title">开发模式 - 选择账号登录</view>
    <button 
      wx:for="{{devUsers}}" 
      wx:key="openid"
      class="dev-btn" 
      bindtap="devLogin" 
      data-openid="{{item.openid}}"
      data-name="{{item.name}}"
      data-role="{{item.role}}">
      {{item.name}}
    </button>
  </view>

  <view wx:else>
    <form bindsubmit="submitForm">
      <view class="form-group">
        <view class="label-row">
          <text class="label">店铺名称 *</text>
        </view>
        <input name="shopName" placeholder="请输入店铺名称" />
      </view>

      <view class="form-group">
        <view class="label-row">
          <text class="label">店主姓名 *</text>
        </view>
        <input name="ownerName" placeholder="请输入店主姓名" />
      </view>

      <view class="form-group">
        <view class="label-row">
          <text class="label">手机号 *</text>
        </view>
        <input name="phone" type="number" maxlength="11" placeholder="请输入手机号" />
      </view>

      <view class="form-group">
        <view class="label-row">
          <text class="label">所在地区</text>
        </view>
        <picker mode="region" bindchange="onRegionChange" value="{{region}}">
          <view class="picker">
            {{region[0]}} {{region[1]}} {{region[2]}}
          </view>
        </picker>
      </view>

      <view class="form-group">
        <view class="label-row">
          <text class="label">详细地址</text>
        </view>
        <input name="detailedAddress" placeholder="请输入详细地址" />
      </view>

      <button class="btn-submit" form-type="submit">提交注册</button>
    </form>
  </view>

  <view class="dev-toggle" bindtap="toggleDevMode">
    <text>{{showDevLogin ? '关闭开发模式' : '开发模式 - 快速登录测试'}}</text>
  </view>
</view>