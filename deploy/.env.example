# Database
DB_USER=petlianbao
DB_PASSWORD=your-strong-password-here
DB_NAME=petlianbao

# Redis
REDIS_PASSWORD=your-redis-password-here

# JWT
JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# WeChat
WECHAT_APP_ID=your-wechat-app-id
