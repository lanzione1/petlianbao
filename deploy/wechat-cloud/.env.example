# 数据库类型
DATABASE_TYPE=mysql

# 微信云托管 MySQL 数据库配置
# 从微信云托管控制台 -> 数据库 获取连接信息
DATABASE_HOST=your-mysql-host.mysql.ap-shanghai.run.tcloudbase.com
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=your-mysql-password
DATABASE_NAME=petlianbao

# Upstash Redis 配置 (可选，没有则使用内存缓存)
# 从 Upstash 控制台获取
REDIS_HOST=xxxxx.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-password
REDIS_TLS=true

# JWT 配置 (生产环境请使用强密码)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# 微信小程序配置
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# CORS 允许的域名 (逗号分隔)
CORS_ORIGINS=https://your-h5-domain.com,https://your-admin-domain.com

# 服务端口 (微信云托管默认 80)
PORT=80
NODE_ENV=production