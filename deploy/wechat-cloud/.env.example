# Supabase PostgreSQL 数据库配置
# 从 Supabase 控制台 -> Settings -> Database 获取
DATABASE_HOST=db.xxxxx.supabase.co
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your-supabase-db-password
DATABASE_NAME=postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Upstash Redis 配置 (可选，没有则使用内存缓存)
# 从 Upstash 控制台获取
REDIS_HOST=xxxxx.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-password
REDIS_TLS=true

# JWT 配置 (生产环境请使用强密码)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# 微信小程序配置
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# CORS 允许的域名 (逗号分隔)
CORS_ORIGINS=https://your-h5-domain.com,https://your-admin-domain.com

# 服务端口 (微信云托管默认 80)
PORT=80
NODE_ENV=production